# ─────────────────────────────────────────────────────────────────────────────
#  Walletly — Environment Variables
#  Copy to .env and fill in every value marked CHANGE_ME.
#  Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=production

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=walletly
POSTGRES_USER=walletly
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_password

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_jwt_secret_at_least_32_chars_xxxxxxxxxxxxxxxxxxxx
JWT_EXPIRES_IN=7d

# Generate: openssl rand -base64 48
SESSION_SECRET=CHANGE_ME_session_secret_at_least_32_chars_xxxxxxxxxxxxxx

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# e.g. https://walletly.example.com,https://www.walletly.example.com
ALLOWED_ORIGINS=http://localhost
